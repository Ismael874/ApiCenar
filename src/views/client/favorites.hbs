{{!-- src/views/client/favorites.hbs --}}
<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-heart text-danger me-2"></i>Mis Favoritos</h2>
    
    <div id="favoritesContainer">
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    </div>
</div>

{{#section "scripts"}}
<script>
const token = localStorage.getItem('token');

async function loadFavorites() {
    try {
        const response = await fetch('/api/favorites', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
            const data = await response.json();
            displayFavorites(data.data);
        }
    } catch (error) {
        console.error('Error:', error);
    }
}

function displayFavorites(favorites) {
    const container = document.getElementById('favoritesContainer');
    
    if (favorites.length === 0) {
        container.innerHTML = `
            <div class="text-center py-5">
                <i class="far fa-heart fa-4x text-muted mb-3"></i>
                <h4>No tienes favoritos</h4>
                <p class="text-muted">Marca comercios como favoritos para verlos aquí</p>
                <a href="/client/home" class="btn btn-primary">Explorar Comercios</a>
            </div>
        `;
        return;
    }
    
    container.innerHTML = `
        <div class="row g-4">
            ${favorites.map(fav => `
                <div class="col-md-6 col-lg-4">
                    <div class="card commerce-card h-100 shadow-sm">
                        <a href="/client/catalog/${fav.commerce.id}">
                            <img src="${fav.commerce.logo}" class="card-img-top" alt="${fav.commerce.name}" style="height: 160px; object-fit: cover;">
                        </a>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="card-title">${fav.commerce.name}</h5>
                                    <p class="card-text text-muted small">${fav.commerce.description || ''}</p>
                                </div>
                                <button class="btn btn-link text-danger p-0" onclick="removeFavorite('${fav.commerce.id}')">
                                    <i class="fas fa-heart-broken"></i>
                                </button>
                            </div>
                            <a href="/client/catalog/${fav.commerce.id}" class="btn btn-primary w-100 mt-2">
                                <i class="fas fa-eye me-2"></i>Ver Catálogo
                            </a>
                        </div>
                    </div>
                </div>
            `).join('')}
        </div>
    `;
}

window.removeFavorite = async function(commerceId) {
    if (!confirm('¿Quitar este comercio de favoritos?')) return;
    
    try {
        const response = await fetch(`/api/favorites/${commerceId}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
            loadFavorites();
        }
    } catch (error) {
        console.error('Error:', error);
    }
};

loadFavorites();
</script>
{{/section}}