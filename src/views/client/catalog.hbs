{{!-- src/views/client/catalog.hbs --}}
<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="/client/home" class="btn btn-outline-secondary me-3">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0" id="commerceName">Catálogo</h2>
    </div>
    
    <div class="row">
        <div class="col-lg-8">
            <div class="commerce-info mb-4 p-3 bg-light rounded" id="commerceInfo"></div>
            <div id="catalogContainer">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="cart-panel p-3">
                <h4 class="mb-3"><i class="fas fa-shopping-cart me-2"></i>Mi Pedido</h4>
                <div id="cartItems"></div>
                <hr>
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal:</span>
                    <strong id="subtotal">RD$ 0.00</strong>
                </div>
                <button class="btn btn-success w-100" id="checkoutBtn" disabled>
                    <i class="fas fa-arrow-right me-2"></i>Continuar
                </button>
            </div>
        </div>
    </div>
</div>

{{#section "scripts"}}
<script>
const commerceId = window.location.pathname.split('/').pop();
const token = localStorage.getItem('token');
let cart = [];

async function loadCatalog() {
    try {
        const response = await fetch(`/api/commerce/${commerceId}/catalog`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
            const data = await response.json();
            displayCommerceInfo(data.commerce);
            displayCatalog(data.catalog);
        }
    } catch (error) {
        console.error('Error:', error);
    }
}

function displayCommerceInfo(commerce) {
    document.getElementById('commerceName').textContent = commerce.name;
    document.getElementById('commerceInfo').innerHTML = `
        <div class="d-flex align-items-center">
            <img src="${commerce.logo}" alt="${commerce.name}" style="width: 60px; height: 60px; object-fit: cover;" class="rounded me-3">
            <div>
                <h5 class="mb-1">${commerce.name}</h5>
                <p class="mb-0 text-muted">${commerce.description || ''}</p>
                <small><i class="fas fa-clock me-1"></i>${commerce.openingTime} - ${commerce.closingTime}</small>
            </div>
        </div>
    `;
}

function displayCatalog(catalog) {
    const container = document.getElementById('catalogContainer');
    
    if (!catalog || catalog.length === 0) {
        container.innerHTML = '<p class="text-center text-muted py-5">No hay productos disponibles</p>';
        return;
    }
    
    container.innerHTML = catalog.map(category => `
        <div class="category-section mb-4">
            <h4 class="mb-3 text-primary">${category.categoryName}</h4>
            <div class="row g-3">
                ${category.products.map(product => `
                    <div class="col-md-6">
                        <div class="product-card p-3">
                            <div class="d-flex">
                                <img src="${product.image}" alt="${product.name}" style="width: 80px; height: 80px; object-fit: cover;" class="rounded me-3">
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">${product.name}</h6>
                                    <p class="text-muted small mb-2">${product.description || ''}</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="text-primary">RD$ ${product.price.toFixed(2)}</strong>
                                        <button class="btn btn-sm btn-outline-primary add-to-cart" 
                                                data-id="${product.id}" 
                                                data-name="${product.name}" 
                                                data-price="${product.price}"
                                                data-image="${product.image}"
                                                ${cart.find(i => i.id === product.id) ? 'disabled' : ''}>
                                            <i class="fas fa-plus"></i> Agregar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `).join('')}
            </div>
        </div>
    `).join('');
    
    document.querySelectorAll('.add-to-cart').forEach(btn => {
        btn.addEventListener('click', () => {
            const product = {
                id: btn.dataset.id,
                name: btn.dataset.name,
                price: parseFloat(btn.dataset.price),
                image: btn.dataset.image,
                quantity: 1
            };
            addToCart(product);
            btn.disabled = true;
        });
    });
}

function addToCart(product) {
    cart.push(product);
    updateCartDisplay();
}

function removeFromCart(productId) {
    cart = cart.filter(item => item.id !== productId);
    updateCartDisplay();
    
    const btn = document.querySelector(`.add-to-cart[data-id="${productId}"]`);
    if (btn) btn.disabled = false;
}

function updateCartDisplay() {
    const container = document.getElementById('cartItems');
    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    
    if (cart.length === 0) {
        container.innerHTML = '<p class="text-muted text-center py-3">No hay productos en el carrito</p>';
        document.getElementById('checkoutBtn').disabled = true;
    } else {
        container.innerHTML = cart.map(item => `
            <div class="cart-item d-flex justify-content-between align-items-center">
                <div>
                    <span class="badge bg-secondary me-2">${item.quantity}</span>
                    <span>${item.name}</span>
                </div>
                <div>
                    <span class="me-2">RD$ ${(item.price * item.quantity).toFixed(2)}</span>
                    <button class="btn btn-sm text-danger remove-item" data-id="${item.id}">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
        `).join('');
        document.getElementById('checkoutBtn').disabled = false;
        
        document.querySelectorAll('.remove-item').forEach(btn => {
            btn.addEventListener('click', () => removeFromCart(btn.dataset.id));
        });
    }
    
    document.getElementById('subtotal').textContent = `RD$ ${subtotal.toFixed(2)}`;
}

document.getElementById('checkoutBtn').addEventListener('click', () => {
    if (cart.length > 0) {
        localStorage.setItem('cart', JSON.stringify(cart));
        localStorage.setItem('checkoutCommerceId', commerceId);
        window.location.href = '/client/checkout';
    }
});

loadCatalog();
</script>
{{/section}}