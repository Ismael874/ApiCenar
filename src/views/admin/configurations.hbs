{{!-- src/views/admin/configurations.hbs --}}
<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-cog me-2"></i>Configuraciones</h2>
    
    <div id="configContainer">
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    </div>
</div>

{{#section "scripts"}}
<script>
const token = localStorage.getItem('token');

async function loadConfigurations() {
    try {
        const response = await fetch('/api/configurations', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
            const data = await response.json();
            displayConfigurations(data.data);
        }
    } catch (error) {
        console.error('Error:', error);
    }
}

function displayConfigurations(configs) {
    const container = document.getElementById('configContainer');
    
    container.innerHTML = `
        <div class="row">
            ${configs.map(c => `
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5>${c.key}</h5>
                            <p class="text-muted">${c.description || ''}</p>
                            <div class="input-group">
                                <input type="${c.type === 'number' ? 'number' : 'text'}" class="form-control" id="val-${c.key}" value="${c.value}" step="0.01">
                                <button class="btn btn-primary" onclick="updateConfig('${c.key}')">Actualizar</button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('')}
        </div>
    `;
}

window.updateConfig = async function(key) {
    const value = document.getElementById(`val-${key}`).value;
    
    try {
        const response = await fetch(`/api/configurations/${key}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body: JSON.stringify({ value })
        });
        
        if (response.ok) {
            alert('Configuración actualizada');
            loadConfigurations();
        }
    } catch (error) {
        console.error('Error:', error);
    }
};

loadConfigurations();
</script>
{{/section}}