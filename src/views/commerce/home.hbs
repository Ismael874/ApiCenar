{{!-- src/views/commerce/home.hbs --}}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-store me-2"></i>Pedidos Recibidos</h2>
        <span class="badge bg-primary" id="orderCount"></span>
    </div>
    
    <div class="mb-3">
        <select class="form-select w-auto" id="statusFilter">
            <option value="">Todos</option>
            <option value="Pending">Pendientes</option>
            <option value="InProgress">En Proceso</option>
            <option value="Completed">Completados</option>
        </select>
    </div>
    
    <div id="ordersContainer">
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    </div>
</div>

{{#section "scripts"}}
<script>
const token = localStorage.getItem('token');
let currentStatus = '';

async function loadOrders() {
    try {
        let url = '/api/orders/commerce?page=1&pageSize=50';
        if (currentStatus) url += `&status=${currentStatus}`;
        
        const response = await fetch(url, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (response.ok) {
            const data = await response.json();
            document.getElementById('orderCount').textContent = `${data.pagination.total} pedidos`;
            displayOrders(data.data);
        }
    } catch (error) {
        console.error('Error:', error);
    }
}

function displayOrders(orders) {
    const container = document.getElementById('ordersContainer');
    
    if (orders.length === 0) {
        container.innerHTML = '<p class="text-center text-muted py-5">No hay pedidos</p>';
        return;
    }
    
    container.innerHTML = orders.map(order => `
        <div class="order-card status-${order.status.toLowerCase()}" onclick="window.location.href='/commerce/orders/${order.id}'">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h6>${order.client.name}</h6>
                    <span class="badge bg-${getStatusColor(order.status)}">${getStatusText(order.status)}</span>
                </div>
                <strong>RD$ ${order.total.toFixed(2)}</strong>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <small><i class="fas fa-box"></i> ${order.itemsCount} productos</small>
                <small><i class="far fa-clock"></i> ${formatDate(order.createdAt)}</small>
            </div>
            ${order.delivery ? `<small class="text-success"><i class="fas fa-motorcycle"></i> Delivery: ${order.delivery.name}</small>` : ''}
        </div>
    `).join('');
}

function getStatusText(s) {
    const map = { 'Pending': 'Pendiente', 'InProgress': 'En Proceso', 'Completed': 'Completado' };
    return map[s] || s;
}

function getStatusColor(s) {
    const map = { 'Pending': 'warning', 'InProgress': 'info', 'Completed': 'success' };
    return map[s] || 'secondary';
}

function formatDate(d) {
    return new Date(d).toLocaleString('es-DO', { dateStyle: 'short', timeStyle: 'short' });
}

document.getElementById('statusFilter').addEventListener('change', (e) => {
    currentStatus = e.target.value;
    loadOrders();
});

loadOrders();
</script>
{{/section}}